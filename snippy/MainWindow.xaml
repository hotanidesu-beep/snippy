<Window x:Class="snippy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:snippy"
        Title="Retro TV Clock" 
        Height="400" Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <!-- TV Frame Geometry -->
        <GeometryGroup x:Key="TvFramePath">
            <!-- Outer Frame -->
            <RectangleGeometry Rect="10,10,180,130" RadiusX="10" RadiusY="10"/>
            <!-- Inner Screen (Cutout) -->
            <RectangleGeometry Rect="20,20,130,110" RadiusX="5" RadiusY="5"/>
        </GeometryGroup>

        <!-- CRT Screen Animation -->
        <Storyboard x:Key="ScanlineAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ScanlineTranslate" 
                             Storyboard.TargetProperty="Y" 
                             From="-110" To="110" 
                             Duration="0:0:5"/>
        </Storyboard>

        <!-- Point Consumption Flash -->
        <Storyboard x:Key="FlashAnim">
            <DoubleAnimation Storyboard.TargetName="FlashOverlay" 
                             Storyboard.TargetProperty="Opacity" 
                             From="0.8" To="0.0" 
                             Duration="0:0:0.5" />
        </Storyboard>
        
        <!-- TV Shake Animation -->
        <Storyboard x:Key="ShakeAnim">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="TvTransform" 
                                           Storyboard.TargetProperty="X" 
                                           Duration="0:0:0.3">
                <LinearDoubleKeyFrame Value="-5" KeyTime="0:0:0.05"/>
                <LinearDoubleKeyFrame Value="5" KeyTime="0:0:0.1"/>
                <LinearDoubleKeyFrame Value="-3" KeyTime="0:0:0.15"/>
                <LinearDoubleKeyFrame Value="3" KeyTime="0:0:0.2"/>
                <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.3"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Sticky notes container (Placed at the bottom of Z-Index so it doesn't block TV clicks) -->
        <Canvas x:Name="StickyNoteCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="True" Panel.ZIndex="0"/>

        <!-- Container for the TV, shifted 100px right and 100px down to allow sticky notes around it -->
        <Grid Margin="100,100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="150" Panel.ZIndex="10">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="TvTransform" X="0" Y="0"/>
            </Grid.RenderTransform>

            <!-- The TV Body -->
            <Path x:Name="TvBodyPath" Fill="#333333" Stroke="#555555" StrokeThickness="2" HorizontalAlignment="Left" VerticalAlignment="Top" Panel.ZIndex="1">
                <Path.Data>
                    <GeometryGroup FillRule="EvenOdd">
                        <!-- Outer TV Box -->
                        <RectangleGeometry x:Name="TvOuterBox" Rect="5,5,190,140" RadiusX="8" RadiusY="8"/>
                        <!-- Screen Area -->
                        <RectangleGeometry x:Name="TvInnerBox" Rect="15,15,140,120" RadiusX="8" RadiusY="8"/>
                    </GeometryGroup>
                </Path.Data>
            </Path>

            <!-- Speaker Grille / Knobs -->
            <StackPanel Margin="160,0,0,0" Width="30" HorizontalAlignment="Left" VerticalAlignment="Center" Panel.ZIndex="2">
                <local:KnobControl x:Name="Knob1" Width="20" Height="20" Margin="0,0,0,10" />
                <Ellipse Width="15" Height="15" Fill="#222" Stroke="#666" StrokeThickness="1" Margin="0,0,0,15" x:Name="Knob2"/>

                <!-- Speaker holes -->
                <Rectangle Width="20" Height="2" Fill="#111" Margin="0,2,0,0"/>
                <Rectangle Width="20" Height="2" Fill="#111" Margin="0,2,0,0"/>
                <Rectangle Width="20" Height="2" Fill="#111" Margin="0,2,0,0"/>
                <Rectangle Width="20" Height="2" Fill="#111" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Screen Content Container (Matches Screen Area Rect) -->
            <Border Margin="15,15,0,0" Width="140" Height="120" HorizontalAlignment="Left" VerticalAlignment="Top" CornerRadius="8" ClipToBounds="True" Panel.ZIndex="2">
                <Grid x:Name="ScreenGrid" Background="#FF0D3A20">

                    <!-- CRT scanline overlay (simulated) -->
                    <Rectangle Fill="#20000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="ScanlineTranslate" Y="0"/>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <!-- CRT Glow -->
                    <Border BorderBrush="#11FFFFFF" BorderThickness="5" CornerRadius="10" Margin="2"/>

                    <!-- Background Effects -->
                    <Canvas x:Name="EffectCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Custom Pixel Art Display Container -->
                        <Canvas x:Name="pixelCanvasTime" Width="100" Height="25" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Canvas.Effect>
                                <DropShadowEffect Color="#FF4AFF70" BlurRadius="5" ShadowDepth="0"/>
                            </Canvas.Effect>
                        </Canvas>

                        <Canvas x:Name="pixelCanvasDate" Width="110" Height="10" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                        <!-- ラックチェック Display Container -->
                        <Canvas x:Name="pixelCanvasSlot" Width="50" Height="10" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <Canvas.Effect>
                                <DropShadowEffect Color="#FFFFD700" BlurRadius="5" ShadowDepth="0"/>
                            </Canvas.Effect>
                        </Canvas>

                        <!-- ラッキー残回数表示 -->
                        <Canvas x:Name="pixelCanvasLucky" Width="40" Height="7" HorizontalAlignment="Center" Margin="0,2,0,0" Visibility="Hidden">
                            <Canvas.Effect>
                                <DropShadowEffect Color="#FFFF6464" BlurRadius="3" ShadowDepth="0"/>
                            </Canvas.Effect>
                        </Canvas>

                        <!-- コンボ表示 -->
                        <Canvas x:Name="pixelCanvasCombo" Width="40" Height="7" HorizontalAlignment="Center" Margin="0,1,0,0" Visibility="Hidden">
                            <Canvas.Effect>
                                <DropShadowEffect Color="#FFFF9600" BlurRadius="3" ShadowDepth="0"/>
                            </Canvas.Effect>
                        </Canvas>

                        <!-- スキル状態表示 -->
                        <Canvas x:Name="pixelCanvasSkill" Width="50" Height="7" HorizontalAlignment="Center" Margin="0,1,0,0" Visibility="Hidden"/>

                        <!-- スライムキャラ -->
                        <Canvas x:Name="pixelCanvasSlime" Width="35" Height="35" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- レリック表示 (画面上部左) -->
                    <Canvas x:Name="pixelCanvasRelics" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,2,0,0" Height="5" Width="60"/>

                    <!-- Points UI (Bottom Right) -->
                    <Canvas x:Name="pixelCanvasPoints" Width="40" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"/>
                    
                    <!-- Flash Overlay for feedback -->
                    <Rectangle x:Name="FlashOverlay" Fill="White" Opacity="0" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                </Grid>
            </Border>

            <!-- Brand Logo Toggle Button -->
            <Button x:Name="btnToggleTodo" Content="todo" Width="40" Height="20" Margin="155,125,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top" 
                    Background="Transparent" Foreground="#FFFFD700" 
                    FontFamily="Comic Sans MS" FontSize="14" FontWeight="Bold" FontStyle="Italic"
                    BorderThickness="0" Click="BtnToggleTodo_Click" Panel.ZIndex="25">
                <Button.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" />
                </Button.Effect>
            </Button>
            
            <!-- Close Button (Moved inside TV Grid) -->
            <Button Content="X" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0" 
                    Background="Red" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnClose_Click" Panel.ZIndex="30"/>
        </Grid>

        <!-- Overlay Canvas (above everything, for confetti/floating text) -->
        <Canvas x:Name="OverlayCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Panel.ZIndex="100"/>

        <!-- Todo List Area (Below TV, outside TV Container) -->
        <Border x:Name="TodoAreaBorder" Visibility="Collapsed" Background="#EE222222" CornerRadius="5" 
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,260,0,0" Width="200" Height="200" Panel.ZIndex="15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtTodoInput" Grid.Row="0" Grid.Column="0" Height="24" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#555" VerticalContentAlignment="Center" Padding="5,0"/>
                <Button x:Name="btnAddTodo" Grid.Row="0" Grid.Column="1" Content="Add" Width="50" Margin="5,0,0,0" Click="BtnAddTodo_Click" Background="#444" Foreground="White"/>

                <ListBox x:Name="lstTodos" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Text}" IsChecked="{Binding IsCompleted}" 
                                      Checked="Todo_Checked" Unchecked="Todo_Unchecked"
                                      Foreground="White" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

    </Grid>
</Window>
